// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ResultCard > snapshots — fail loudly on layout / glyph / palette drift > error with hint 1`] = `
"✗  Boom

↳ hint: Try again."
`;

exports[`ResultCard > snapshots — fail loudly on layout / glyph / palette drift > info with next-steps 1`] = `
"i  No sprints yet

Next
  → ralphctl sprint create — start a draft
  → ralphctl project add — register a repo first"
`;

exports[`ResultCard > snapshots — fail loudly on layout / glyph / palette drift > success bare title 1`] = `"✓  Done"`;

exports[`ResultCard > snapshots — fail loudly on layout / glyph / palette drift > success with fields + lines + hint + next-steps 1`] = `
"✓  Sprint closed

name:        demo
tasks:       12

/tmp/ralphctl/sprints/demo/

↳ hint: next: run \`ralphctl sprint create-pr\`

Next
  → ralphctl sprint show — inspect closed sprint"
`;

exports[`ResultCard > snapshots — fail loudly on layout / glyph / palette drift > warning with fields 1`] = `
"⚠  Tasks incomplete

done:        3
remaining:   2"
`;
