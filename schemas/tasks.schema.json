{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks.schema.json",
  "title": "Tasks",
  "description": "Array of tasks in a sprint",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "status", "order", "projectPath"],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1,
        "description": "Task ID (uuid8)"
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Task name"
      },
      "description": {
        "type": "string",
        "description": "Task description"
      },
      "steps": {
        "type": "array",
        "default": [],
        "description": "Implementation steps",
        "items": {
          "type": "string"
        }
      },
      "status": {
        "type": "string",
        "enum": ["todo", "in_progress", "done"],
        "default": "todo",
        "description": "Task status (kanban: todo → in_progress → done)"
      },
      "order": {
        "type": "integer",
        "minimum": 1,
        "description": "Task priority order"
      },
      "ticketId": {
        "type": "string",
        "description": "Reference to parent ticket (internal ID)"
      },
      "blockedBy": {
        "type": "array",
        "default": [],
        "description": "Task IDs that must complete before this task can start",
        "items": {
          "type": "string"
        }
      },
      "projectPath": {
        "type": "string",
        "minLength": 1,
        "description": "Absolute path to the project directory for execution"
      },
      "verified": {
        "type": "boolean",
        "default": false,
        "description": "Whether the task passed verification"
      },
      "verificationOutput": {
        "type": "string",
        "description": "Output from the verification run"
      },
      "evaluated": {
        "type": "boolean",
        "default": false,
        "description": "Whether the evaluator ran on this task"
      },
      "evaluationOutput": {
        "type": "string",
        "description": "Output from the evaluation run (truncated to 2000 chars)"
      }
    }
  }
}
