@startuml
' Ideate chain — ralphctl sprint ideate
' Factory: src/application/chains/ideate/ideate-flow.ts
' Step trace: load-sprint → assert-draft → load-project → ideate-and-plan → save-sprint → save-tasks
title ralphctl — Ideate chain (kernel framework)

autonumber

actor User
participant CLI as "CLI / TUI\n(prompts for idea + project)"
participant SM as "SessionManager"
participant Chain as "Sequential('ideate')"
participant UC as "Use cases\n(business)"
participant AI as "AI"
database sprint.json
database tasks.json

User -> CLI : ralphctl sprint ideate
CLI -> CLI : prompt for project + free-text idea
note right: HITL — captured before chain starts
CLI -> SM : start({ element, initialCtx={ sprintId, ideaText, project } })

SM -> Chain : execute(ctx)
activate Chain

Chain -> UC : LoadSprintUseCase
note right: trace: load-sprint

Chain -> Chain : Sprint.status === 'draft'
note right: trace: assert-draft

Chain -> UC : ShowProjectUseCase
note right: trace: load-project

Chain -> UC : IdeateAndPlanUseCase
note right: trace: ideate-and-plan
UC -> AI : spawnHeadless(ideate.md\n+ idea + sprint context)
activate AI
AI --> UC : structured\n<ticket>...<tasks>
deactivate AI
UC -> UC : parse → { Ticket, Task[] }\n(ticket auto-approved\nticketId auto-assigned to tasks)
UC --> Chain : { ticket, tasks }

Chain -> UC : SaveSprintUseCase\n(sprint with new ticket)
note right: trace: save-sprint
UC -> sprint.json : save

Chain -> UC : TaskRepository.saveAll
note right: trace: save-tasks
UC -> tasks.json : atomically replace

Chain --> SM : Result.ok({ ctx, trace })
deactivate Chain
SM --> CLI : completed
CLI --> User : new ticket + task count

@enduml
