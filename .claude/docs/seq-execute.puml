@startuml
' Execute chain — ralphctl sprint start
' Factory: src/application/chains/execute/execute-flow.ts (outer) + per-task-flow.ts (inner)
' Outer trace: load-sprint → assert-active → load-tasks → assert-tasks-not-empty →
'              dirty-tree-preflight → check-scripts-sprint-start → link-skills →
'              execute-tasks (Parallel of bridged per-task chains) → unlink-skills
' Per-task trace: branch-preflight (OnError → mark-blocked) → mark-in-progress →
'                 execute-task (Retry rate-limited; OnError aborted → mark-blocked-cancelled) →
'                 post-task-check → recover-dirty-tree → evaluate-task (OnError catchAll → noop) →
'                 mark-done
title ralphctl — Execute chain (outer + per-task)

autonumber

actor User
participant CLI as "CLI / TUI"
participant SM as "SessionManager"
participant Outer as "Sequential('execute')"
participant Parallel as "Parallel('execute-tasks')\n(kernel)"
participant PerTask as "Sequential('per-task-<id>')"
participant UC as "Use cases\n(business)"
participant Loop as "EvaluateAndFixLoop\n(business)"
participant Prompt as "PromptPort"
participant AI as "AI"
database sprint.json
database tasks.json
database progress.md
database evaluations as "<sprintDir>/evaluations/<taskId>.md"

User -> CLI : ralphctl sprint start
CLI -> SM : start({ element=createExecuteFlow, ctx })
SM -> Outer : execute(ctx)
activate Outer

Outer -> UC : LoadSprintUseCase
note right: trace: load-sprint
Outer -> Outer : Sprint.status === 'active'\n(else InvalidStateError —\nlauncher activates draft sprints first)
note right: trace: assert-active
Outer -> UC : ListTasksUseCase
note right: trace: load-tasks
Outer -> Outer : tasks.length > 0
note right: trace: assert-tasks-not-empty

Outer -> UC : DirtyTreePreflightUseCase\n(survey unique repo paths)
note right: trace: dirty-tree-preflight
opt any repo dirty
    UC -> Prompt : "Uncommitted changes detected — stash / reset / continue / cancel?"
    alt user cancelled
        UC --> Outer : InvalidStateError 'dirty-tree-cancelled'\n(chain ends; no tasks launched)
    end
end

opt sprint-level checkScript configured
    Outer -> UC : ExternalPort.runCheckScript(cwd, script, 'sprint-start')
    note right: trace: check-scripts-sprint-start
    alt check failed
        UC --> Outer : InvalidStateError 'check-failed'
    end
end

Outer -> UC : LinkSkillsUseCase
note right: trace: link-skills

Outer -> Parallel : children = tasks.map(task => bridge(createPerTaskFlow))
activate Parallel
note right: concurrency=4 (default), failureMode='collect-all'\n(per-task failures don't abort siblings)

loop each task in parallel
    Parallel -> PerTask : execute(perTaskCtx)
    activate PerTask

    PerTask -> UC : BranchPreflightUseCase\n(via OnError(catchIf: invalid-state))
    note right: trace: branch-preflight
    alt branch mismatch (invalid-state)
        UC --> PerTask : InvalidStateError
        PerTask -> PerTask : OnError fallback → markBlockedFallbackLeaf\n(reason: "Branch preflight failed: ...")
        note right: trace: mark-blocked\nctx.taskBlocked = true\n(every downstream leaf no-ops,\ntrace stays honest)
    end

    PerTask -> UC : task.markInProgress() + taskRepo.update\n(no-op when taskBlocked)
    note right: trace: mark-in-progress

    PerTask -> UC : ExecuteSingleTaskUseCase\n(wrapped in Retry then OnError)
    note right: trace: execute-task\nRetry maxAttempts=2 retryOn: code='rate-limited'\nOnError catchIf: code='aborted' (user cancel)
    UC -> AI : spawnHeadless(task-execution.md)
    activate AI
    AI --> UC : signals (progress / verified / complete / blocked)
    deactivate AI
    alt rate-limited
        UC --> PerTask : KernelError code='rate-limited'\n(Retry re-runs; final attempt propagates)
    else user-aborted (Ctrl+C / TUI 'c')
        UC --> PerTask : KernelError code='aborted'
        PerTask -> PerTask : OnError fallback → markCancelledFallbackLeaf\n(reason: "cancelled by user")
        note right: trace: mark-blocked\nctx.taskBlocked = true
    end

    PerTask -> UC : PostTaskCheckUseCase\n(skipped when taskBlocked OR no checkScript)
    note right: trace: post-task-check

    PerTask -> UC : RecoverDirtyTreeUseCase\n(skipped when taskBlocked)
    note right: trace: recover-dirty-tree

    PerTask -> Loop : EvaluateAndFixLoopUseCase\n(reads liveConfig.evaluationIterations\nfresh per task — REQ-12)
    note right: trace: evaluate-task\n(wrapped in OnError(catchIf: () => true)\n— evaluator never blocks the task)
    opt taskBlocked
        Loop --> PerTask : { task: ctx.task } (skip)
    end
    loop up to evaluationIterations rounds
        Loop -> AI : spawnHeadless(task-evaluation.md\n+ previousCritique?)
        AI --> Loop : EvaluationSignal
        alt failed AND not at iteration cap AND no plateau
            Loop -> AI : resume generator with critique
            AI --> Loop : new signals
            Loop -> UC : PostTaskCheckUseCase (inter-round)
        end
    end
    Loop --> PerTask : { rounds, finalSignal, finalCritique, plateau }
    PerTask -> UC : task.recordEvaluation(...) + taskRepo.update\n(preview ≤2000 chars)
    PerTask -> evaluations : write full critique\n(harness owns the write — adapter\noutside this chain)

    PerTask -> UC : task.markDone() + taskRepo.update\n(no-op when taskBlocked OR outcome != 'completed')
    note right: trace: mark-done

    PerTask --> Parallel : Result.ok / blocked
    deactivate PerTask
end

Parallel --> Outer : reduced ctx (last child snapshot)
deactivate Parallel

Outer -> UC : UnlinkSkillsUseCase
note right: trace: unlink-skills

Outer --> SM : Result.ok({ ctx, trace })
deactivate Outer
SM --> CLI : completed
CLI --> User : execution summary

note over CLI
  Feedback is its OWN chain (createFeedbackFlow) —
  not embedded here. The CLI/TUI launches it as a
  separate session after executeFlow settles.
end note

@enduml
