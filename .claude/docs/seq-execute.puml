@startuml
' Execute chain — ralphctl sprint start
' Factory: src/application/chains/execute/execute-flow.ts (outer) + per-task-flow.ts (inner)
' Outer trace: load-sprint → assert-active → load-tasks → assert-tasks-not-empty → check-scripts-sprint-start → link-skills → execute-tasks (Parallel) → unlink-skills
' Inner trace (per task): branch-preflight → mark-in-progress → execute-task → post-task-check → recover-dirty-tree → evaluate-task → mark-done
title ralphctl — Execute chain (outer + per-task)

autonumber

actor User
participant CLI as "CLI / TUI"
participant SM as "SessionManager"
participant Outer as "Sequential('execute')"
participant Parallel as "Parallel('execute-tasks')\n(kernel)"
participant PerTask as "Sequential('per-task')"
participant UC as "Use cases\n(business)"
participant AI as "AI"
participant Eval as "EvaluateAndFixLoop\n(business)"
database sprint.json
database tasks.json
database progress.md

User -> CLI : ralphctl sprint start
CLI -> SM : start({ element=createExecuteFlow, ctx })
SM -> Outer : execute(ctx)
activate Outer

Outer -> UC : LoadSprintUseCase
note right: trace: load-sprint
Outer -> Outer : Sprint.status === 'active'\n(else auto-activate then assert)
note right: trace: assert-active
Outer -> UC : ListTasksUseCase
note right: trace: load-tasks
Outer -> Outer : tasks.length > 0
note right: trace: assert-tasks-not-empty
Outer -> UC : runCheckScripts (sprint-start phase)
note right: trace: check-scripts-sprint-start
Outer -> UC : LinkSkillsUseCase
note right: trace: link-skills

Outer -> Parallel : children = tasks.map(task => createPerTaskFlow)
activate Parallel
note right: concurrency=4, failureMode='collect-all'

loop each task in parallel (mutex by projectPath)
    Parallel -> PerTask : execute(taskCtx)
    activate PerTask

    PerTask -> UC : BranchPreflightUseCase
    note right: trace: branch-preflight\n(OnError fallback → markBlocked)

    PerTask -> UC : EditTaskStatus(markInProgress)
    note right: trace: mark-in-progress

    PerTask -> UC : ExecuteSingleTaskUseCase
    note right: trace: execute-task#attempt-1\n(Retry on rate-limited, max 2)
    UC -> AI : spawnHeadless(task-execution.md)
    activate AI
    AI --> UC : signals (progress / verified / complete)
    deactivate AI

    PerTask -> UC : PostTaskCheckUseCase
    note right: trace: post-task-check\n(skips when no changed files)

    PerTask -> UC : RecoverDirtyTreeUseCase
    note right: trace: recover-dirty-tree

    PerTask -> Eval : EvaluateAndFixLoopUseCase\n(reads liveConfig.evaluationIterations\nfresh per task)
    note right: trace: evaluate-task
    loop up to evaluationIterations rounds
        Eval -> AI : spawnHeadless(task-evaluation.md)
        AI --> Eval : EvaluationSignal
        alt failed AND not at iteration cap AND no plateau
            Eval -> AI : resume generator with critique
        end
    end
    Eval --> PerTask : { rounds, finalSignal, plateauDetected }
    PerTask -> progress.md : append evaluation summary

    PerTask -> UC : EditTaskStatus(markDone)
    note right: trace: mark-done

    PerTask --> Parallel : Result.ok / blocked / failed
    deactivate PerTask
end

Parallel --> Outer : reduced ctx (per-task outcomes)
deactivate Parallel

Outer -> UC : UnlinkSkillsUseCase
note right: trace: unlink-skills

Outer --> SM : Result.ok({ ctx, trace })
deactivate Outer
SM --> CLI : completed
CLI --> User : execution summary

@enduml
