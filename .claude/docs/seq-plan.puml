@startuml
' Plan chain — ralphctl sprint plan
' Factory: src/application/chains/plan/plan-flow.ts
' Step trace: load-sprint → assert-draft → assert-all-tickets-approved →
'             load-existing-tasks → confirm-replan → plan-tasks →
'             reorder-tasks → confirm-task-list → save-tasks
title ralphctl — Plan chain (kernel framework)

autonumber

actor User
participant CLI as "CLI / TUI\n(repo multi-select happens\nbefore chain starts)"
participant SM as "SessionManager"
participant Chain as "Sequential('plan')\n(application/chains)"
participant UC as "Use cases\n(business)"
participant Algo as "Kernel algorithms\n(dependency-reorder)"
participant Prompt as "PromptPort"
participant AI as "AI"
database sprint.json
database tasks.json

User -> CLI : ralphctl sprint plan
note right of CLI: repo multi-select prompt\n(persists to ticket.affectedRepositories)\nbecomes additionalRepoPaths
CLI -> SM : start({ element=createPlanFlow, initialCtx, opts })
SM -> Chain : execute(ctx)
activate Chain

Chain -> UC : LoadSprintUseCase
note right: trace: load-sprint

Chain -> Chain : Sprint.status === 'draft'
note right: trace: assert-draft

Chain -> Chain : every ticket\nrequirementStatus === 'approved'
note right: trace: assert-all-tickets-approved

Chain -> UC : ListTasksUseCase\n(existing tasks for replan context)
note right: trace: load-existing-tasks
UC -> tasks.json : findBySprintId
UC --> Chain : Task[]\n(empty for first plan)

opt interactive AND existingTasks.length > 0
    Chain -> Prompt : confirm("<n> task(s) exist. Replan will replace them all. Continue?")
    note right: trace: confirm-replan
    Prompt --> Chain : proceed?
    alt user declined
        Chain --> SM : Result.error(InvalidStateError 'replan-cancelled')
    end
end

Chain -> UC : PlanSprintTasksUseCase\n+ interactive (when set)\n+ outputFilePath (interactive)\n+ runInTerminal (interactive)\n+ additionalRepoPaths → --add-dir
note right: trace: plan-tasks
UC -> AI : interactive: stdio inherit (Claude UI)\nheadless: spawnHeadless(plan-common.md\n+ tickets + existing tasks)
activate AI
AI --> UC : interactive: write tasks.json\nheadless: structured stdout
deactivate AI
UC -> UC : parse → Task[]\n(via Task.create())
UC --> Chain : Task[]

Chain -> Algo : topologicalReorder(tasks by blockedBy)
note right: trace: reorder-tasks
Algo --> Chain : reordered Task[]\n(or cycle / unknown-dep error)

opt interactive AND tasks.length > 0
    Chain -> Prompt : confirm("Approve the planned tasks and save?")\nwith details = task list summary (scrollable)
    note right: trace: confirm-task-list
    Prompt --> Chain : accept?
    alt user rejected
        Chain --> SM : Result.error(InvalidStateError 'task-list-rejected')\n(save-tasks NEVER runs — atomic)
    end
end

Chain -> UC : TaskRepository.save\n→ atomically replace
note right: trace: save-tasks
UC -> tasks.json : write

Chain --> SM : Result.ok({ ctx, trace })
deactivate Chain
SM --> CLI : completed
CLI --> User : new task count, step trace

@enduml
