@startuml
'https://plantuml.com/sequence-diagram
' ralphctl TARGET pipeline flows — aspirational state informed by:
'   - Anthropic: Effective Harnesses for Long-Running Agents
'     https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents
'   - Anthropic: Harness Design for Long-Running Apps
'     https://www.anthropic.com/engineering/harness-design-long-running-apps
'   - Saga orchestration pattern (Microsoft Learn, AWS Prescriptive Guidance)
'   - Worker pool + durable workflow replay (Temporal-style resumption)
'
' Diff this against seq.puml to see the roadmap.
' TODO items are marked with `**TODO**` in notes; ARCHITECTURE.md "Future Work"
' section tracks ownership.

title ralphctl — TARGET state (post-roadmap) Refine / Plan / Execute sequence flows

autonumber

actor User
participant Harness as "Harness\n(pipeline runner)"
participant AI as "AI\n(Claude / Copilot)"
participant Code as "Code\n(target repo)"
database sprint.json
database task.json
database contract.md as "contract.md\n(per-task;\n**TODO**)"
database progress.md
database evaluation.md

== Refine ==

User -> Harness : ralphctl sprint refine
activate Harness

note over Harness: createRefinePipeline\n(pipelines/refine.ts)

Harness -> sprint.json : load sprint + tickets
note right of Harness: step: load-sprint

Harness -> Harness : assert-draft

loop per pending ticket
    Harness -> AI : spawn refine session\n(ticket-refine.md)
    activate AI
    AI -> User : ask clarifying questions
    User --> AI : answers
    AI --> Harness : requirements.json
    deactivate AI
    Harness -> User : approve?
    User --> Harness : yes
    Harness -> sprint.json : persist requirements\n+ requirementStatus='approved'
end

alt all approved
    note over Harness
        step: export-requirements
        //Structured artifact as handoff//
        //(Anthropic: Effective Harnesses)//
    end note
    Harness -> Code : write requirements.md (sprint dir)
end

Harness --> User : RefineSummary
deactivate Harness

== Plan ==

User -> Harness : ralphctl sprint plan
activate Harness

note over Harness: createPlanPipeline\n(pipelines/plan.ts)

Harness -> sprint.json : load sprint
Harness -> Harness : assert-draft
Harness -> Harness : assert-all-approved
Harness -> task.json : getTasks (re-plan detection)

alt existing tasks
    Harness -> User : confirm re-plan?
    User --> Harness : confirm
end

Harness -> User : select repositories
User --> Harness : selected

Harness -> sprint.json : persist ticket.affectedRepositories

Harness -> AI : spawn plan session\n(plan prompt + schema + tooling)
activate AI
AI -> Code : explore repos (read-only)
AI --> Harness : tasks.json
deactivate AI

Harness -> Harness : validate (Zod)
Harness -> task.json : importTasks (replace on re-plan)
Harness -> task.json : reorderByDependencies

note over Harness
    **TODO** (Future Work):
    Planner emits //dimension scores// + //success thresholds//
    per generated task, not just verificationCriteria bullets.
    Unlocks calibrated evaluator grading downstream.
    (Anthropic: hard thresholds per criterion)
end note

Harness --> User : PlanSummary
deactivate Harness

== Execute ==

User -> Harness : ralphctl sprint start
activate Harness

note over Harness: createExecuteSprintPipeline\n(pipelines/execute.ts)

Harness -> sprint.json : load sprint
Harness -> Harness : check-preconditions
Harness -> User : branch strategy?
User --> Harness : choice
Harness -> sprint.json : activate if draft
Harness -> Harness : assert-active
Harness -> task.json : reorder + getTasks
Harness -> Code : ensure-branches (verify-only, no auto-recover)
Harness -> Code : run-check-scripts (baseline)
Harness -> sprint.json : record checkRanAt

note over Harness
    step: execute-tasks
    forEachTask(PerTaskPipeline, ...)
    **TODO**: rename to `forEachItem` once a
    second use-site appears (batch ops, multi-sprint)
end note

note over Harness
    **TODO** (layering cleanup):
    RateLimitCoordinator lives in src/integration/ai/
    but is constructed from src/business/pipelines/execute.ts.
    Add RateLimitCoordinatorPort factory to SharedDeps so the
    business layer stops reaching into integration.
end note

loop while tasks remain
    Harness -> task.json : pullItems (in-progress + ready)

    group per-task saga (concurrent up to limit, mutex by projectPath)

        alt sprint.branch set
            Harness -> Code : verifyBranch
            note right of Harness: step: branch-preflight\n//saga compensation://\nBranchPreflightError → requeue (≤3)
        end

        note over Harness
            **TODO** (new step before mark-in-progress):
            step: negotiate-contract
            Harness writes <sprintDir>/contracts/<taskId>.md
            combining: verificationCriteria, resolved checkScript,
            evaluator dimensions, hard thresholds.
            Both generator and evaluator read this file —
            the explicit //sprint contract// pattern from
            Anthropic's harness-design article.
            (user-flagged: verification steps prompted in initial phase)
        end note

        Harness -> contract.md : write task contract\n**TODO**

        Harness -> task.json : mark-in-progress
        Harness -> Harness : emit task-started

        Harness -> AI : spawn Generator\n(task-execution.md\n+ contract.md ref)
        activate AI

        note over AI
            **TODO** (session resumption):
            if taskSessionIds.has(task.id):
              spawn with --resume <sessionId>
            Current code captures sessionId on rate-limit
            but never threads it into the next launch.
        end note

        loop streaming
            AI -> Code : read / edit / test
            AI --> Harness : harness signals
            Harness -> progress.md : append
        end

        AI --> Harness : result
        deactivate AI

        alt rate-limited
            note right of Harness: retryPolicy → pause-all + requeue\n//saga compensation//
        end

        Harness -> task.json : store-verification
        Harness -> Code : post-task check gate

        alt check failed
            note right of Harness: retryPolicy → skip-repo\n//saga compensation//
        end

        note over Harness
            step: evaluate-task
            nested(createEvaluatorPipeline)
            fresh config read (REQ-12)
        end note

        alt evaluationIterations > 0 && !noEvaluate
            Harness -> contract.md : read contract\n**TODO**

            loop up to N rounds (model ladder;\nplateau detection)
                Harness -> AI : spawn Evaluator\n(task-evaluation.md\n+ contract.md\n+ few-shot calibration)
                activate AI

                note over AI
                    **TODO** (calibration):
                    Few-shot examples with detailed score breakdowns
                    tune the evaluator to grade consistently.
                    (Anthropic: "I calibrated the evaluator using
                    few-shot examples with detailed score breakdowns")
                end note

                AI -> Code : read diff + tests + contract
                AI --> Harness : <evaluation-passed> |\n<evaluation-failed>critique\n+ dimension scores
                deactivate AI
                Harness -> evaluation.md : append critique + scores

                note over Harness
                    **TODO** (plateau detection):
                    Compare scores to previous iteration.
                    If scores unchanged across 2 consecutive rounds,
                    short-circuit loop ("ceiling reached") instead
                    of wasting further fix attempts.
                    (Anthropic: "evaluator's assessments improved
                    over iterations before plateauing")
                end note

                Harness -> task.json : evaluationOutput preview\n+ evaluationStatus

                alt failed && attempts remain && score improved
                    Harness -> AI : resume Generator with critique
                    activate AI
                    AI -> Code : fix
                    AI --> Harness : updated result
                    deactivate AI
                    Harness -> Code : re-run checkScript
                else passed / exhausted / plateau
                    note right: loop breaks
                end
            end
        end

        Harness -> task.json : mark-done
        Harness -> progress.md : logProgress
    end

    alt "--step"
        Harness -> User : continue?
        User --> Harness : yes/no
    end
end

alt stopReason=all_completed && !session && !noFeedback
    note over Harness: step: feedback-loop\n(end-of-sprint only,\nMAX_FEEDBACK_ITERATIONS cap)
    loop bounded
        Harness -> User : feedback?
        User --> Harness : text (empty exits)
        alt non-empty
            Harness -> AI : spawn feedback session
            activate AI
            AI -> Code : implement
            AI --> Harness : result
            deactivate AI
            Harness -> Code : re-run checkScripts
            Harness -> AI : evaluator on affected tasks
            activate AI
            AI --> Harness : pass / fail
            deactivate AI
        end
    end
end

Harness --> User : ExecutionSummary
deactivate Harness

note across
    ==== Roadmap summary (tracked in .claude/docs/ARCHITECTURE.md "Future Work") ====
    1. **Sprint contract step**       — explicit per-task contract.md before execute-task.
                                         Generator and evaluator read the same contract.
    2. **Plateau detection**          — short-circuit evaluator loop when scores stop improving.
    3. **Evaluator calibration**      — few-shot examples with scored breakdowns in prompt.
    4. **Session-id resume wiring**   — thread captured sessionId into --resume on relaunch.
    5. **forEachTask generalization** — rename to forEachItem at 2nd use-site.
    6. **Layering fix**               — RateLimitCoordinatorPort in SharedDeps, drop the
                                         business → integration import.
    7. **Legacy dead-code purge**     — delete src/integration/ai/executor.ts + runner.ts
                                         + their tests (~1400 LOC, closed loop, unreachable).
    8. **Planner dimension emission** — tasks carry structured thresholds, not just bullet
                                         verificationCriteria.
end note

@enduml
