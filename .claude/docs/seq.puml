@startuml
'https://plantuml.com/sequence-diagram
' ralphctl pipeline flows — source of truth for Refine, Plan, Execute.
' Each message is annotated with the pipeline step that emits it.
' Pipeline step factories live in src/business/pipelines/.

title ralphctl — Refine / Plan / Execute sequence flows

autonumber

actor User
participant Harness as "Harness\n(pipeline runner)"
participant AI as "AI\n(Claude / Copilot)"
participant Code as "Code\n(target repo)"
database task.json
database progress.md
database evaluation.md

== Refine ==

User -> Harness : ralphctl sprint refine
activate Harness

note over Harness: createRefinePipeline\n(pipelines/refine.ts)

Harness -> task.json : read sprint + tickets
note right of Harness: step: load-sprint

Harness -> Harness : verify sprint.status == 'draft'
note right of Harness: step: assert-draft

note over Harness: step: refine-tickets\n(loops per pending ticket)

loop for each ticket where requirementStatus == 'pending'
    Harness -> AI : spawn session\n(ticket-refine.md template\n+ ticket + issue context)
    activate AI
    AI -> User : ask clarifying questions (HITL)
    User -> AI : answers
    AI --> Harness : requirements.json (structured output)
    deactivate AI
    Harness -> User : show refined requirements + approve?
    User --> Harness : approve
    Harness -> task.json : write ticket.requirements\n+ requirementStatus = 'approved'
end

alt all tickets approved
    note over Harness: step: export-requirements
    Harness -> Code : write <sprintDir>/requirements.md
end

Harness --> User : RefineSummary\n(approved / skipped / total)
deactivate Harness

== Plan ==

User -> Harness : ralphctl sprint plan
activate Harness

note over Harness: createPlanPipeline\n(pipelines/plan.ts)

Harness -> task.json : read sprint + tickets
note right of Harness: step: load-sprint

Harness -> Harness : verify sprint.status == 'draft'
note right of Harness: step: assert-draft

Harness -> Harness : verify every ticket.requirementStatus == 'approved'
note right of Harness: step: assert-all-approved\n(ParseError if any pending)

note over Harness: step: run-plan
Harness -> task.json : getTasks (re-plan detection)

alt existing tasks && !auto
    Harness -> User : confirm re-plan (will replace tasks)?
    User --> Harness : confirm
end

Harness -> User : select affected repositories\n(or use saved / --all-paths)
User --> Harness : selected repos

Harness -> task.json : persist ticket.affectedRepositories

Harness -> AI : spawn session\n(plan prompt + schema + tooling)
activate AI
AI -> Code : explore repos (read-only)
AI --> Harness : tasks.json (generated)
deactivate AI

Harness -> Harness : validate tasks (Zod + import rules)
Harness -> task.json : importTasks (replace on re-plan)

note over Harness: step: reorder-dependencies\n(skipped if zero imported)
Harness -> task.json : reorderByDependencies

Harness --> User : PlanSummary\n(imported / totalGenerated / isReplan)
deactivate Harness

== Execute ==

User -> Harness : ralphctl sprint start
activate Harness

note over Harness: createExecuteSprintPipeline\n(pipelines/execute.ts)

Harness -> task.json : read sprint
note right of Harness: step: load-sprint

Harness -> Harness : warn unrefined / unplanned tickets\n(skipped with --force)
note right of Harness: step: check-preconditions

alt sprint.status == 'draft' && unrefined tickets exist
    Harness -> User : start anyway without refining?
    User --> Harness : confirm / decline
end

Harness -> User : branch strategy? (keep / auto / custom)
User --> Harness : branch choice
note right of Harness: step: resolve-branch

alt sprint.status == 'draft'
    Harness -> task.json : activateSprint
    note right of Harness: step: auto-activate
end

Harness -> Harness : verify sprint.status == 'active'
note right of Harness: step: assert-active

Harness -> task.json : reorderByDependencies + getTasks
note right of Harness: step: prepare-tasks

alt branchName is set
    Harness -> Code : check uncommitted changes per repo
    Harness -> Code : git checkout -b <branch>
    Harness -> task.json : persist sprint.branch
    note right of Harness: step: ensure-branches
end

Harness -> Code : run checkScript per repo (baseline)
Harness -> task.json : record sprint.checkRanAt
note right of Harness: step: run-check-scripts\n(sprint-start mode;\nskipped paths with prior run)

note over Harness: step: execute-tasks\nforEachTask(PerTaskPipeline, ...)\npulls ready + in-progress each tick,\nmutex key = projectPath,\nconcurrency 1..10 auto

loop while tasks remain and not stopped
    Harness -> task.json : pullItems\n(in-progress + ready)

    group per-task pipeline (may run concurrently up to limit)

        alt sprint.branch set
            Harness -> Code : verifyBranch(task.projectPath, sprint.branch)
            note right of Harness: step: branch-preflight\n(BranchPreflightError → requeue,\nup to 3 retries)
        end

        Harness -> task.json : updateTaskStatus(in_progress)
        Harness -> Harness : emit signal 'task-started'
        note right of Harness: step: mark-in-progress

        Harness -> AI : spawn session\n(task-execution.md + task + context)
        activate AI

        loop AI streaming output
            AI -> Code : read / edit / test
            AI --> Harness : harness signals\n(<progress>, <task-verified>,\n<task-complete>, <note>, <task-blocked>)
            Harness -> progress.md : append ProgressSignal / NoteSignal
            Harness -> Harness : emit signal event (SignalBus)
        end

        AI --> Harness : session result (success / blocked / rate-limited)
        deactivate AI

        alt rate-limited (SpawnError.rateLimited)
            note right of Harness: retryPolicy → pause-all\n+ requeue item\n(onPause emits\n'rate-limit-paused')
        else task not completed
            note right of Harness: retryPolicy → fail\n(drainInFlight if failFast)
        end
        note right of Harness: step: execute-task

        alt result.verified
            Harness -> task.json : updateTask(verified, verificationOutput)
            note right of Harness: step: store-verification
        end

        Harness -> Code : run checkScript (post-task gate)
        alt check failed
            Harness -> task.json : (task stays in_progress)
            note right of Harness: retryPolicy → skip-repo\n(repo blocked for further tasks)
        end
        note right of Harness: step: post-task-check

        note over Harness: step: evaluate-task\nnested(createEvaluatorPipeline)\nfresh config read (REQ-12)

        alt evaluationIterations > 0
            Harness -> task.json : read task + verificationCriteria
            note right of Harness: nested step: load-task

            alt task.evaluated && !force
                note right of Harness: nested step:\ncheck-already-evaluated\n(skip evaluator)
            else run evaluator loop
                loop up to evaluationIterations+1 rounds (model ladder)
                    Harness -> AI : spawn Evaluator session\n(task-evaluation.md\n+ sibling model)
                    activate AI
                    AI -> Code : read diff, tests, CLAUDE.md
                    AI --> Harness : <evaluation-passed> |\n<evaluation-failed>critique
                    deactivate AI
                    Harness -> evaluation.md : append full critique\n(evaluations/<taskId>.md)
                    Harness -> task.json : evaluationOutput preview\n+ evaluationStatus + evaluated=true
                    alt failed && attempts remain
                        Harness -> AI : resume Generator\nwith critique\n(task-evaluation-resume.md)
                        activate AI
                        AI -> Code : fix per critique
                        AI --> Harness : updated result
                        deactivate AI
                        Harness -> Code : re-run checkScript
                    else passed or attempts exhausted
                        note right: loop breaks;\ntask never blocked\non eval failure
                    end
                end
            end
        end

        Harness -> task.json : updateTaskStatus(done)
        Harness -> Harness : emit signal 'task-finished'
        Harness -> progress.md : logProgress(task completed)
        note right of Harness: step: mark-done

    end

    alt step mode (--step)
        Harness -> User : continue to next task?
        User --> Harness : continue / stop
        note right of Harness: forEachTask 'between' hook
    end
end

note over Harness: (forEachTask disposes coordinator\n+ emits 'rate-limit-resumed'\nif paused)

alt summary.stopReason == 'all_completed'\n&& !session && !noFeedback
    note over Harness: step: feedback-loop\n(end-of-sprint only)
    loop up to MAX_FEEDBACK_ITERATIONS
        Harness -> User : free-form feedback?
        User --> Harness : text (empty = exit)
        alt non-empty
            Harness -> AI : spawn feedback session\n(sprint-feedback.md)
            activate AI
            AI -> Code : implement feedback
            AI --> Harness : result
            deactivate AI
            Harness -> Code : re-run checkScripts
            Harness -> AI : evaluator on affected tasks
            activate AI
            AI --> Harness : pass / fail
            deactivate AI
        end
    end
end

Harness --> User : ExecutionSummary\n(completed / remaining / blocked /\nstopReason / exitCode)
deactivate Harness

@enduml
