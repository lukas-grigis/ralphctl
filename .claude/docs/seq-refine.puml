@startuml
' Refine chain — ralphctl sprint refine
' Factory: src/application/chains/refine/refine-flow.ts
' Step trace: load-sprint → assert-draft → link-skills → refine-tickets (Sequential of per-ticket sub-chains) → unlink-skills
title ralphctl — Refine chain (kernel framework)

autonumber

actor User
participant CLI as "CLI / TUI\n(launch entry)"
participant SM as "SessionManager\n(application/runtime)"
participant Runner as "ChainRunner\n(kernel/runtime)"
participant Chain as "Sequential('refine')\n(application/chains)"
participant UC as "Use cases\n(business)"
participant AI as "AI\n(Claude / Copilot)"
database sprint.json

User -> CLI : ralphctl sprint refine\n(or TUI Refine)

CLI -> SM : start({ element, initialCtx, label })
activate SM
SM -> Runner : new ChainRunner(...)
activate Runner
Runner -> Chain : execute(ctx, abortSignal, onTrace)
activate Chain

Chain -> UC : LoadSprintUseCase
note right: trace: load-sprint
UC -> sprint.json : findById
UC --> Chain : sprint

Chain -> Chain : Sprint.status === 'draft'
note right: trace: assert-draft

Chain -> UC : LinkSkillsUseCase\n(integration/ai/skills)
note right: trace: link-skills

note over Chain: trace: refine-tickets\n(Sequential per pending ticket)
loop each ticket where requirementStatus = 'pending'
    Chain -> UC : RefineSingleTicketUseCase
    note right: trace: refine-<ticketId>
    UC -> AI : spawnHeadless(ticket-refine.md prompt)
    activate AI
    AI --> UC : structured output
    deactivate AI
    UC --> Chain : updated Ticket\n(requirementStatus='approved')
    Chain -> UC : SaveSprintUseCase
    note right: trace: save-after-<ticketId>
    UC -> sprint.json : save
end

Chain -> UC : UnlinkSkillsUseCase
note right: trace: unlink-skills

Chain --> Runner : Result.ok({ ctx, trace })
deactivate Chain
Runner --> SM : status = 'completed'
deactivate Runner

SM -> CLI : event: { type: 'task-finished' }
deactivate SM

CLI --> User : sessionId, trace, summary

@enduml
