@startuml
' Refine chain — ralphctl sprint refine
' Factory: src/application/chains/refine/refine-flow.ts
' Outer trace: load-sprint → assert-draft → link-skills → refine-tickets (Sequential of per-ticket sub-chains) → unlink-skills
' Per-ticket sub-chain trace: refine-<id> → save-after-<id>
title ralphctl — Refine chain (kernel framework)

autonumber

actor User
participant CLI as "CLI / TUI\n(launch entry)"
participant SM as "SessionManager\n(application/runtime)"
participant Runner as "ChainRunner\n(kernel/runtime)"
participant Chain as "Sequential('refine')\n(application/chains)"
participant PerTicket as "Sequential('refine-<id>')\n(per-ticket sub-chain)"
participant UC as "Use cases\n(business)"
participant Ext as "ExternalPort\n(gh / glab)"
participant Prompt as "PromptPort"
participant AI as "AI\n(Claude / Copilot)"
database sprint.json

User -> CLI : ralphctl sprint refine\n(or TUI Refine)

CLI -> SM : start({ element=createRefineFlow, initialCtx, label })
activate SM
SM -> Runner : new ChainRunner(...)
activate Runner
Runner -> Chain : execute(ctx, abortSignal, onTrace)
activate Chain

Chain -> UC : LoadSprintUseCase
note right: trace: load-sprint
UC -> sprint.json : findById
UC --> Chain : sprint

Chain -> Chain : Sprint.status === 'draft'
note right: trace: assert-draft

Chain -> UC : LinkSkillsUseCase\n(integration/ai/skills)
note right: trace: link-skills

note over Chain: trace: refine-tickets\n(Sequential per pending ticket —\nstep count fixed at chain construction)
loop each ticket where requirementStatus = 'pending'
    Chain -> PerTicket : execute(ctx)
    activate PerTicket

    note over PerTicket: trace: refine-<ticketId>\n(per-ticket leaf)

    alt interactive mode (TTY)
        PerTicket -> AI : ensureReady() (resolve provider)
        PerTicket -> Prompt : confirm("Start refinement session for [<id>] <title>?")
        Prompt --> PerTicket : proceed?
        opt user declined
            PerTicket --> Chain : Result.ok(sprint unchanged)\n(skip to next ticket)
        end
    end

    opt ticket.link defined
        PerTicket -> Ext : fetchIssue(link)
        note right: gh / glab — non-fatal\n(failure logs warn, proceeds without)
        Ext --> PerTicket : issue context (or null)
    end

    PerTicket -> UC : RefineSingleTicketUseCase.execute(...)\n+ outputFilePath (interactive)\n+ runInTerminal (interactive)\n+ reviewBeforeApprove (interactive)\n+ issueContext (when fetched)
    UC -> AI : interactive: stdio inherit (Claude UI)\nheadless: spawnHeadless(ticket-refine.md)
    activate AI
    AI --> UC : interactive: write requirements.json\nheadless: structured stdout
    deactivate AI

    alt interactive mode
        UC -> Prompt : reviewBeforeApprove(proposedRequirements)
        note right: confirm("Approve refined requirements for [<id>]?")\nwith details = parsed body (scrollable)
        Prompt --> UC : accept?
        opt reviewer rejected
            UC --> PerTicket : { accepted: false }
            PerTicket --> Chain : Result.ok(sprint unchanged)
        end
    end

    UC --> PerTicket : { ticket (requirementStatus='approved'), accepted: true }
    PerTicket -> PerTicket : sprint.replaceTicket(id, refined)
    note right: trace: refine-<ticketId>

    PerTicket -> UC : SaveSprintUseCase
    note right: trace: save-after-<ticketId>\n(persist BEFORE next ticket — resumable)
    UC -> sprint.json : save

    PerTicket --> Chain : Result.ok({ sprint, refinedTickets += [...] })
    deactivate PerTicket
end

Chain -> UC : UnlinkSkillsUseCase
note right: trace: unlink-skills

Chain --> Runner : Result.ok({ ctx, trace })
deactivate Chain
Runner --> SM : status = 'completed'
deactivate Runner

SM -> CLI : event: { type: 'task-finished' }
deactivate SM

CLI --> User : sessionId, trace, summary

@enduml
