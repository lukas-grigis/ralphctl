@startuml
' Onboard chain — ralphctl project onboard <name>
' Factory: src/application/chains/onboard/onboard-flow.ts
' Step trace: load-project → resolve-repo → detect-existing-files →
'             confirm-start-ai → run-onboard-ai →
'             confirm-setup-script → confirm-verify-script →
'             confirm-context-file → write-context-file →
'             save-repo-scripts
title ralphctl — Onboard chain (AI-assisted repo setup)

autonumber

actor User
participant CLI as "CLI / TUI"
participant SM as "SessionManager"
participant Chain as "Sequential('onboard')"
participant UC as "Use cases\n(business)"
participant Prompt as "PromptPort"
participant AI as "AI"
database projects.json
database repo as "<repoPath>/{CLAUDE.md\n| .github/copilot-instructions.md}"

User -> CLI : ralphctl project onboard <name>\n  [--repo <path>] [--auto] [--dry-run]
CLI -> SM : start({ element=createOnboardFlow,\n  ctx={ projectName, repoPath?, autoAccept } })
SM -> Chain : execute(ctx)
activate Chain

Chain -> UC : projectRepo.findByName(projectName)
note right: trace: load-project

Chain -> Chain : resolve repo from project.repositories\n(by --repo path; or unique repo;\nor InvalidStateError if ambiguous)
note right: trace: resolve-repo

Chain -> Chain : scan repo for CLAUDE.md / copilot-instructions.md / AGENTS.md
note right: trace: detect-existing-files
opt pre-existing files found WITHOUT harness marker
    Chain -> Prompt : confirm("Files exist. Mark as externally managed?")\n(auto-accepts when autoAccept=true)
    Prompt --> Chain : externallyManaged?
    alt user accepted (or autoAccept)
        Chain -> Chain : ctx.externallyManaged = true
        note right
          From here every leaf no-ops EXCEPT
          save-repo-scripts which only stamps
          onboardedAt. The repo is marked
          onboarded without modifying files.
        end note
    end
end

opt NOT externallyManaged AND NOT autoAccept
    Chain -> Prompt : confirm("Start <provider> onboarding session for <repo>?")
    note right: trace: confirm-start-ai
    Prompt --> Chain : proceed?
    alt declined
        Chain -> Chain : ctx.externallyManaged = true\n(equivalent to "no AI runs")
    end
end

opt NOT externallyManaged
    Chain -> UC : OnboardRepoUseCase
    note right: trace: run-onboard-ai
    UC -> AI : spawnHeadless(onboard.md\n+ repo path + project context\n+ mode: bootstrap | adopt | update)
    activate AI
    AI --> UC : signals\n  <setup-script>...</setup-script>\n  <verify-script>...</verify-script>\n  <agents-md>...</agents-md>\n  <skill-suggestions>name1, name2, ...</skill-suggestions>
    deactivate AI
    UC -> UC : security denylist on scripts\n(drop pipe-to-shell, curl|sh,\neval, rm -rf variants)
    UC --> Chain : OnboardRepoProposals\n  { setupScript?, verifyScript?,\n    contextFile?, skillSuggestions[] }
end

opt NOT externallyManaged AND NOT autoAccept
    Chain -> Prompt : "Accept setup script?"\nwith details = proposed body
    note right: trace: confirm-setup-script
    Prompt --> Chain : ctx.acceptedSetupScript ∈ { string | null }

    Chain -> Prompt : "Accept verify script?"
    note right: trace: confirm-verify-script
    Prompt --> Chain : ctx.acceptedVerifyScript ∈ { string | null }

    Chain -> Prompt : "Accept project context file?"\nwith details = proposed body
    note right: trace: confirm-context-file
    Prompt --> Chain : ctx.acceptedContextFile ∈ { string | null }
end

opt NOT externallyManaged AND ctx.acceptedContextFile is string
    Chain -> Chain : prepend harness marker\n<!-- ralphctl onboard: <ISO> -->
    Chain -> repo : write provider-native file\n(CLAUDE.md for claude,\n.github/copilot-instructions.md for copilot)
    note right: trace: write-context-file\nNo symlinks, no pointer files.
end

Chain -> UC : projectRepo.update with\nrepository.{setupScript, checkScript,\nonboardedAt: IsoTimestamp.now()}
note right: trace: save-repo-scripts
UC -> projects.json : save

Chain --> SM : Result.ok({ ctx, trace })
deactivate Chain
SM --> CLI : completed
CLI --> User : per-artefact summary

@enduml
