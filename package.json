{
  "name": "ralphctl",
  "version": "0.1.0",
  "description": "CLI tool for Ralph operations",
  "type": "module",
  "bin": {
    "ralphctl": "./bin/ralphctl"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.3.2",
    "colorette": "^2.0.20",
    "commander": "^14.0.3",
    "ora": "^9.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^4.0.18"
  }
}
