{
  "name": "ralphctl",
  "version": "0.7.1",
  "description": "Agent harness for long-running AI coding tasks — orchestrates Claude Code & GitHub Copilot across repositories",
  "homepage": "https://github.com/lukas-grigis/ralphctl",
  "type": "module",
  "license": "MIT",
  "author": "Lukas Grigis",
  "repository": {
    "type": "git",
    "url": "https://github.com/lukas-grigis/ralphctl.git"
  },
  "bugs": {
    "url": "https://github.com/lukas-grigis/ralphctl/issues"
  },
  "keywords": [
    "cli",
    "agent-harness",
    "claude-code",
    "github-copilot",
    "ai-coding",
    "task-orchestration",
    "anthropic",
    "developer-tools",
    "long-running-agents",
    "generator-evaluator"
  ],
  "bin": {
    "ralphctl": "./dist/cli.mjs"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsx scripts/build-assets.ts",
    "prepublishOnly": "pnpm build",
    "dev": "NODE_OPTIONS=--max-old-space-size=8192 tsx src/index.ts",
    "start": "NODE_OPTIONS=--max-old-space-size=8192 tsx src/index.ts",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:unused": "tsx scripts/find-unused.ts",
    "deadcode": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^7.0.3",
    "react": "^19.2.6",
    "typescript-result": "^3.5.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "jiti": "^2.7.0",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": "prettier --write"
  }
}
